{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Production Log Diagnosis",
  "version": "0.1.0",
  "identifier": "com.loganalysis.desktop.v1",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "产线日志诊断",
        "width": 1380,
        "height": 900,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGQTU3QUE1OUVBNjMyOTgKUldTWU1xYWVwWHFsN3dnUXh0M1VpZFhhNjNIdm8rQXpnQXZhb1ZEVmcvQVp0Y1pSVTJyZm1qdU8K",
      "endpoints": [
        "https://github.com/zhaoyang8518/tools-releases/releases/download/log-analysis-latest/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
